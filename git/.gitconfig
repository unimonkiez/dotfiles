[user]
  name = Yuval Saraf
  email = yuvalsaraf@gmail.com

[pull]
  rebase = true

[core]
  editor = code --wait

[init]
  defaultBranch = master

[diff]
  tool = vscode

[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE

[merge]
  tool = vscode

[mergetool "vscode"]
  cmd = code --wait $MERGED

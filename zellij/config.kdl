keybinds clear-defaults=true {
    shared_except "locked" {
        bind "Ctrl q" { Quit; }

        // Ghostty-style Super (Cmd) keybindings — no prefix, no mode switch needed
        bind "Super t" { NewTab; SwitchToMode "Normal"; }
        bind "Super w" { CloseFocus; SwitchToMode "Normal"; }
        bind "Super Alt Left"  { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "Super Alt Right" { GoToNextTab; SwitchToMode "Normal"; }
        bind "Super h" { NewPane "Left";  SwitchToMode "Normal"; }
        bind "Super j" { NewPane "Down";  SwitchToMode "Normal"; }
        bind "Super k" { NewPane "Up";    SwitchToMode "Normal"; }
        bind "Super l" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "Super Alt h" { MoveFocus "Left";  SwitchToMode "Normal"; }
        bind "Super Alt j" { MoveFocus "Down";  SwitchToMode "Normal"; }
        bind "Super Alt k" { MoveFocus "Up";    SwitchToMode "Normal"; }
        bind "Super Alt l" { MoveFocus "Right"; SwitchToMode "Normal"; }
        bind "Super Shift h" { Resize "Increase Left"; }
        bind "Super Shift j" { Resize "Increase Down"; }
        bind "Super Shift k" { Resize "Increase Up"; }
        bind "Super Shift l" { Resize "Increase Right"; }
        bind "Ctrl Shift Pageup"   { MoveTab "Left"; }
        bind "Ctrl Shift Pagedown" { MoveTab "Right"; }
        bind "Super Shift c" { EditScrollback; }
        bind "Super 1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "Super 2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "Super 3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "Super 4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "Super 5" { GoToTab 5; SwitchToMode "Normal"; }
        bind "Super 6" { GoToTab 6; SwitchToMode "Normal"; }
        bind "Super 7" { GoToTab 7; SwitchToMode "Normal"; }
        bind "Super 8" { GoToTab 8; SwitchToMode "Normal"; }
        bind "Super 9" { GoToTab 9; SwitchToMode "Normal"; }
    }
}

plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    compact-bar location="zellij:compact-bar"
    session-manager location="zellij:session-manager"
    welcome-screen location="zellij:session-manager" {
        welcome_screen false
    }
    filepicker location="zellij:strider" {
        cwd "/"
    }
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
    about location="zellij:about"
}

load_plugins {
    "zellij:link"
}

pane_frames true

themes {
    catppuccin-mocha {
        fg      205 214 244  // #cdd6f4  text
        bg       30  30  46  // #1e1e2e  base
        black    69  71  90  // #45475a  surface1
        red     243 139 168  // #f38ba8  red
        green   166 227 161  // #a6e3a1  green
        yellow  249 226 175  // #f9e2af  yellow
        blue    137 180 250  // #89b4fa  blue
        magenta 203 166 247  // #cba6f7  mauve
        cyan    137 220 235  // #89dceb  sky
        white   205 214 244  // #cdd6f4  text
        orange  250 179 135  // #fab387  peach
    }
}

theme "catppuccin-mocha"

layout_dir "/Users/yuvalsaraf/.config/zellij/layouts"
default_layout "main"

scrollback_editor "nvim"

web_client {
    font "monospace"
}
